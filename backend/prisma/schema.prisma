// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// =============================================================
// Enums
// =============================================================

enum AvailabilityStatus {
  available
  busy
  offline
}

enum ProficiencyLevel {
  beginner
  intermediate
  advanced
  expert
}

enum ServiceStatus {
  draft
  open
  in_progress
  completed
  cancelled
}

enum ProposalStatus {
  pending
  accepted
  rejected
  withdrawn
}

// =============================================================
// Models
// =============================================================

model Role {
  id        Int        @id @default(autoincrement()) @db.UnsignedTinyInt
  name      String     @unique @db.VarChar(50)
  userRoles UserRole[]

  @@map("roles")
}

model User {
  id                 BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  uuid               Bytes     @unique @db.Binary(16)
  email              String    @unique @db.VarChar(255)
  passwordHash       String?   @map("password_hash") @db.VarChar(255)
  googleId           String?   @unique @map("google_id") @db.VarChar(255)
  firstName          String    @map("first_name") @db.VarChar(100)
  lastName           String    @map("last_name") @db.VarChar(100)
  phoneNumber        String?   @unique @map("phone_number") @db.VarChar(20)
  profilePictureUrl  String?   @map("profile_picture_url") @db.VarChar(2048)
  isEmailVerified    Boolean   @default(false) @map("is_email_verified")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  // Relations
  roles               UserRole[]
  professionalProfile ProfessionalProfile?
  services            Service[]
  reviewsWritten      Review[]             @relation("ReviewerRelation")
  reviewsReceived     Review[]             @relation("ReviewedRelation")

  @@index([email])
  @@index([googleId])
  @@index([deletedAt])
  @@map("users")
}

model UserRole {
  userId    BigInt   @map("user_id") @db.UnsignedBigInt
  roleId    Int      @map("role_id") @db.UnsignedTinyInt
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Category {
  id          Int        @id @default(autoincrement()) @db.UnsignedInt
  name        String     @unique @db.VarChar(100)
  description String?    @db.VarChar(255)
  parentId    Int?       @map("parent_id") @db.UnsignedInt

  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryTree")
  services    Service[]

  @@index([parentId])
  @@map("categories")
}

model Skill {
  id            Int            @id @default(autoincrement()) @db.UnsignedInt
  name          String         @unique @db.VarChar(100)
  profileSkills ProfileSkill[]

  @@map("skills")
}

model ProfessionalProfile {
  userId             BigInt              @id @map("user_id") @db.UnsignedBigInt
  headline           String?             @db.VarChar(255)
  bio                String?             @db.Text
  hourlyRate         Decimal             @default(0.00) @map("hourly_rate") @db.Decimal(10, 2)
  isVerified         Boolean             @default(false) @map("is_verified")
  averageRating      Decimal             @default(0.00) @map("average_rating") @db.Decimal(3, 2)
  totalReviews       Int                 @default(0) @map("total_reviews") @db.UnsignedInt
  availabilityStatus AvailabilityStatus  @default(available) @map("availability_status")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills    ProfileSkill[]
  proposals Proposal[]

  @@index([availabilityStatus])
  @@index([averageRating(sort: Desc)])
  @@index([isVerified])
  @@map("professional_profiles")
}

model ProfileSkill {
  professionalProfileId BigInt           @map("professional_profile_id") @db.UnsignedBigInt
  skillId               Int              @map("skill_id") @db.UnsignedInt
  proficiencyLevel      ProficiencyLevel @default(intermediate) @map("proficiency_level")

  professionalProfile ProfessionalProfile @relation(fields: [professionalProfileId], references: [userId], onDelete: Cascade)
  skill               Skill               @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([professionalProfileId, skillId])
  @@index([skillId])
  @@map("profile_skills")
}

model Service {
  id          BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  uuid        Bytes         @unique @db.Binary(16)
  clientId    BigInt        @map("client_id") @db.UnsignedBigInt
  categoryId  Int           @map("category_id") @db.UnsignedInt
  title       String        @db.VarChar(255)
  description String        @db.Text
  budgetMin   Decimal?      @map("budget_min") @db.Decimal(10, 2)
  budgetMax   Decimal?      @map("budget_max") @db.Decimal(10, 2)
  status      ServiceStatus @default(draft)
  deadline    DateTime?     @db.Date
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  client    User      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  proposals Proposal[]
  reviews   Review[]

  @@index([clientId])
  @@index([categoryId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("services")
}

model Proposal {
  id               BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  uuid             Bytes          @unique @db.Binary(16)
  serviceId        BigInt         @map("service_id") @db.UnsignedBigInt
  professionalId   BigInt         @map("professional_id") @db.UnsignedBigInt
  proposedPrice    Decimal        @map("proposed_price") @db.Decimal(10, 2)
  coverLetter      String?        @map("cover_letter") @db.Text
  deliveryTimeDays Int?           @map("delivery_time_days") @db.UnsignedInt
  status           ProposalStatus @default(pending)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  service      Service             @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  professional ProfessionalProfile @relation(fields: [professionalId], references: [userId], onDelete: Cascade)

  @@unique([serviceId, professionalId])
  @@index([serviceId])
  @@index([professionalId])
  @@index([status])
  @@map("proposals")
}

model Review {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  serviceId  BigInt   @map("service_id") @db.UnsignedBigInt
  reviewerId BigInt   @map("reviewer_id") @db.UnsignedBigInt
  reviewedId BigInt   @map("reviewed_id") @db.UnsignedBigInt
  rating     Int      @db.UnsignedTinyInt // 1–5
  comment    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  service  Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  reviewer User    @relation("ReviewerRelation", fields: [reviewerId], references: [id], onDelete: Restrict)
  reviewed User    @relation("ReviewedRelation", fields: [reviewedId], references: [id], onDelete: Restrict)

  @@unique([serviceId, reviewerId, reviewedId])
  @@index([reviewedId])
  @@index([rating(sort: Desc)])
  @@map("reviews")
}
