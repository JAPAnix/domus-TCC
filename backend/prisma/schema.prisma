// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ============================================================
// AUTENTICAÇÃO & USUÁRIOS
// ============================================================

model User {
  id                  BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  uuid                Bytes     @unique @db.Binary(16)
  email               String    @unique @db.VarChar(255)
  passwordHash        String    @map("password_hash") @db.VarChar(255)
  firstName           String    @map("first_name") @db.VarChar(100)
  lastName            String    @map("last_name") @db.VarChar(100)
  phoneNumber         String?   @unique @map("phone_number") @db.VarChar(20)
  profilePictureUrl   String?   @map("profile_picture_url") @db.VarChar(2048)
  isEmailVerified     Boolean   @default(false) @map("is_email_verified")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  // Relações
  userRoles                UserRole[]
  userSocialAuths          UserSocialAuth[]
  userSessions             UserSession[]
  professionalProfile      ProfessionalProfile?
  services                 Service[]              @relation("ClientServices")
  paymentsMade             Payment[]              @relation("PayerPayments")
  paymentsReceived         Payment[]              @relation("PayeePayments")
  wallet                   Wallet?
  reviewsGiven             Review[]               @relation("ReviewerReviews")
  reviewsReceived          Review[]               @relation("ReviewedReviews")
  notifications            Notification[]
  conversationParticipants ConversationParticipant[]
  messagesSent             Message[]
  attachmentsUploaded      Attachment[]
  proposalHistoryChanges   ProposalHistory[]      @relation("ProposalHistoryChanger")
  favorites                Favorite[]
  reportsSubmitted         Report[]               @relation("ReporterReports")
  reportsAgainst           Report[]               @relation("ReportedUserReports")
  adminLogs                AdminLog[]
  userSubscriptions        UserSubscription[]

  @@index([email])
  @@index([createdAt])
  @@map("users")
}

model Role {
  id        Int        @id @default(autoincrement()) @db.UnsignedTinyInt
  name      String     @unique @db.VarChar(50)
  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  userId    BigInt   @map("user_id") @db.UnsignedBigInt
  roleId    Int      @map("role_id") @db.UnsignedTinyInt
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model UserSocialAuth {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId       BigInt    @map("user_id") @db.UnsignedBigInt
  provider     String    @db.VarChar(50)
  providerId   String    @map("provider_id") @db.VarChar(255)
  accessToken  String?   @map("access_token") @db.Text
  refreshToken String?   @map("refresh_token") @db.Text
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
  @@map("user_social_auth")
}

model UserSession {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId       BigInt   @map("user_id") @db.UnsignedBigInt
  sessionToken String   @unique @map("session_token") @db.VarChar(255)
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.Text
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

// ============================================================
// CATEGORIAS & PERFIS
// ============================================================

model Category {
  id          Int        @id @default(autoincrement()) @db.UnsignedInt
  uuid        Bytes      @unique @db.Binary(16)
  name        String     @unique @db.VarChar(100)
  description String?    @db.Text
  parentId    Int?       @map("parent_id") @db.UnsignedInt
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  children Category[] @relation("CategoryParent")
  services Service[]

  @@index([parentId])
  @@index([name])
  @@map("categories")
}

model ProfessionalProfile {
  userId              BigInt                    @id @map("user_id") @db.UnsignedBigInt
  uuid                Bytes                     @unique @db.Binary(16)
  headline            String?                   @db.VarChar(255)
  bio                 String?                   @db.Text
  hourlyRate          Decimal                   @default(0.00) @map("hourly_rate") @db.Decimal(10, 2)
  portfolioUrl        String?                   @map("portfolio_url") @db.VarChar(2048)
  isVerified          Boolean                   @default(false) @map("is_verified")
  averageRating       Decimal                   @default(0.00) @map("average_rating") @db.Decimal(3, 2)
  totalReviews        Int                       @default(0) @map("total_reviews") @db.UnsignedInt
  responseTimeHours   Int?                      @map("response_time_hours") @db.UnsignedInt
  availabilityStatus  AvailabilityStatus        @default(available) @map("availability_status")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  profileSkills ProfileSkill[]
  proposals     Proposal[]
  serviceSquads ServiceSquad[]
  favorites     Favorite[]

  @@index([averageRating(sort: Desc)])
  @@index([isVerified])
  @@index([availabilityStatus])
  @@map("professional_profiles")
}

model Skill {
  id            Int            @id @default(autoincrement()) @db.UnsignedInt
  uuid          Bytes          @unique @db.Binary(16)
  name          String         @unique @db.VarChar(100)
  profileSkills ProfileSkill[]

  @@map("skills")
}

model ProfileSkill {
  professionalProfileId BigInt           @map("professional_profile_id") @db.UnsignedBigInt
  skillId               Int              @map("skill_id") @db.UnsignedInt
  proficiencyLevel      ProficiencyLevel @default(intermediate) @map("proficiency_level")
  createdAt             DateTime         @default(now()) @map("created_at")

  professionalProfile ProfessionalProfile @relation(fields: [professionalProfileId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  skill               Skill               @relation(fields: [skillId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([professionalProfileId, skillId])
  @@index([skillId])
  @@map("profile_skills")
}

// ============================================================
// SERVIÇOS & PROPOSTAS
// ============================================================

model Service {
  id          BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  uuid        Bytes         @unique @db.Binary(16)
  clientId    BigInt        @map("client_id") @db.UnsignedBigInt
  categoryId  Int           @map("category_id") @db.UnsignedInt
  title       String        @db.VarChar(255)
  description String        @db.Text
  budgetMin   Decimal?      @map("budget_min") @db.Decimal(10, 2)
  budgetMax   Decimal?      @map("budget_max") @db.Decimal(10, 2)
  status      ServiceStatus @default(draft)
  deadline    DateTime?     @db.Date
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  client        User           @relation("ClientServices", fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  category      Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  proposals     Proposal[]
  serviceSquads ServiceSquad[]
  payments      Payment[]
  reviews       Review[]
  conversations Conversation[]
  attachments   Attachment[]
  favorites     Favorite[]
  reports       Report[]

  @@index([clientId])
  @@index([categoryId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([deadline])
  @@map("services")
}

model Proposal {
  id               BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  uuid             Bytes          @unique @db.Binary(16)
  serviceId        BigInt         @map("service_id") @db.UnsignedBigInt
  professionalId   BigInt         @map("professional_id") @db.UnsignedBigInt
  proposedPrice    Decimal        @map("proposed_price") @db.Decimal(10, 2)
  coverLetter      String?        @map("cover_letter") @db.Text
  deliveryTimeDays Int?           @map("delivery_time_days") @db.UnsignedInt
  status           ProposalStatus @default(pending)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  service      Service             @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  professional ProfessionalProfile @relation(fields: [professionalId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  history      ProposalHistory[]

  @@unique([serviceId, professionalId])
  @@index([serviceId])
  @@index([professionalId])
  @@index([status])
  @@map("proposals")
}

model ProposalHistory {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  proposalId BigInt   @map("proposal_id") @db.UnsignedBigInt
  changeType String   @map("change_type") @db.VarChar(50)
  oldValue   String?  @map("old_value") @db.Text
  newValue   String?  @map("new_value") @db.Text
  changedAt  DateTime @default(now()) @map("changed_at")
  changedBy  BigInt?  @map("changed_by") @db.UnsignedBigInt

  proposal  Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  changedByUser User? @relation("ProposalHistoryChanger", fields: [changedBy], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([proposalId])
  @@index([changedAt(sort: Desc)])
  @@map("proposals_history")
}

model ServiceSquad {
  id                     BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  uuid                   Bytes    @unique @db.Binary(16)
  serviceId              BigInt   @map("service_id") @db.UnsignedBigInt
  professionalId         BigInt   @map("professional_id") @db.UnsignedBigInt
  roleInSquad            String?  @map("role_in_squad") @db.VarChar(100)
  paymentSharePercentage Decimal? @map("payment_share_percentage") @db.Decimal(5, 2)
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  service      Service             @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  professional ProfessionalProfile @relation(fields: [professionalId], references: [userId], onDelete: Cascade, onUpdate: Cascade)

  @@index([serviceId])
  @@index([professionalId])
  @@map("service_squads")
}

// ============================================================
// PAGAMENTOS & CARTEIRA
// ============================================================

model Payment {
  id                    BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  uuid                  Bytes         @unique @db.Binary(16)
  serviceId             BigInt        @map("service_id") @db.UnsignedBigInt
  payerId               BigInt        @map("payer_id") @db.UnsignedBigInt
  payeeId               BigInt        @map("payee_id") @db.UnsignedBigInt
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("BRL") @db.VarChar(3)
  transactionType       TransactionType @map("transaction_type")
  paymentMethod         String?       @map("payment_method") @db.VarChar(50)
  status                PaymentStatus @default(pending)
  transactionDate       DateTime      @default(now()) @map("transaction_date")
  processedAt           DateTime?     @map("processed_at")
  externalTransactionId String?       @unique @map("external_transaction_id") @db.VarChar(255)
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  service              Service             @relation(fields: [serviceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  payer                User                @relation("PayerPayments", fields: [payerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  payee                User                @relation("PayeePayments", fields: [payeeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  walletTransactions   WalletTransaction[]

  @@index([serviceId])
  @@index([payerId])
  @@index([payeeId])
  @@index([status])
  @@index([transactionDate(sort: Desc)])
  @@map("payments")
}

model Wallet {
  userId    BigInt   @id @map("user_id") @db.UnsignedBigInt
  uuid      Bytes    @unique @db.Binary(16)
  balance   Decimal  @default(0.00) @db.Decimal(12, 2)
  currency  String   @default("BRL") @db.VarChar(3)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id              BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  uuid            Bytes                    @unique @db.Binary(16)
  walletId        BigInt                   @map("wallet_id") @db.UnsignedBigInt
  paymentId       BigInt?                  @map("payment_id") @db.UnsignedBigInt
  amount          Decimal                  @db.Decimal(10, 2)
  transactionType WalletTransactionType    @map("transaction_type")
  description     String?                  @db.Text
  status          WalletTransactionStatus  @default(completed)
  createdAt       DateTime                 @default(now()) @map("created_at")

  wallet  Wallet   @relation(fields: [walletId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([walletId])
  @@index([paymentId])
  @@index([createdAt(sort: Desc)])
  @@map("wallet_transactions")
}

// ============================================================
// AVALIAÇÕES, NOTIFICAÇÕES & FAVORITOS
// ============================================================

model Review {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  uuid       Bytes    @unique @db.Binary(16)
  serviceId  BigInt   @map("service_id") @db.UnsignedBigInt
  reviewerId BigInt   @map("reviewer_id") @db.UnsignedBigInt
  reviewedId BigInt   @map("reviewed_id") @db.UnsignedBigInt
  rating     Int      @db.UnsignedTinyInt
  comment    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  service  Service @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  reviewer User    @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  reviewed User    @relation("ReviewedReviews", fields: [reviewedId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([serviceId, reviewerId, reviewedId])
  @@index([serviceId])
  @@index([reviewerId])
  @@index([reviewedId])
  @@index([rating(sort: Desc)])
  @@map("reviews")
}

model Notification {
  id        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  uuid      Bytes     @unique @db.Binary(16)
  userId    BigInt    @map("user_id") @db.UnsignedBigInt
  type      String    @db.VarChar(50)
  message   String    @db.Text
  isRead    Boolean   @default(false) @map("is_read")
  sentAt    DateTime  @default(now()) @map("sent_at")
  readAt    DateTime? @map("read_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([sentAt(sort: Desc)])
  @@map("notifications")
}

model Favorite {
  userId         BigInt   @map("user_id") @db.UnsignedBigInt
  professionalId BigInt?  @map("professional_id") @db.UnsignedBigInt
  serviceId      BigInt?  @map("service_id") @db.UnsignedBigInt
  createdAt      DateTime @default(now()) @map("created_at")

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  professional ProfessionalProfile? @relation(fields: [professionalId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  service      Service?             @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // Nota: Prisma não suporta PK composta com campos nullable nativamente.
  // Use um campo id separado ou trate via lógica de aplicação.
  @@id([userId, professionalId, serviceId])
  @@index([userId])
  @@index([professionalId])
  @@index([serviceId])
  @@map("favorites")
}

// ============================================================
// CONVERSAS & MENSAGENS
// ============================================================

model Conversation {
  id        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  uuid      Bytes     @unique @db.Binary(16)
  serviceId BigInt?   @map("service_id") @db.UnsignedBigInt
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  service      Service?                  @relation(fields: [serviceId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([serviceId])
  @@map("conversations")
}

model ConversationParticipant {
  conversationId BigInt   @map("conversation_id") @db.UnsignedBigInt
  userId         BigInt   @map("user_id") @db.UnsignedBigInt
  joinedAt       DateTime @default(now()) @map("joined_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  uuid           Bytes    @unique @db.Binary(16)
  conversationId BigInt   @map("conversation_id") @db.UnsignedBigInt
  senderId       BigInt   @map("sender_id") @db.UnsignedBigInt
  messageText    String   @map("message_text") @db.Text
  sentAt         DateTime @default(now()) @map("sent_at")
  isRead         Boolean  @default(false) @map("is_read")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  attachments  Attachment[]

  @@index([conversationId])
  @@index([senderId])
  @@index([sentAt(sort: Desc)])
  @@map("messages")
}

model Attachment {
  id            BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  uuid          Bytes    @unique @db.Binary(16)
  messageId     BigInt?  @map("message_id") @db.UnsignedBigInt
  serviceId     BigInt?  @map("service_id") @db.UnsignedBigInt
  uploaderId    BigInt   @map("uploader_id") @db.UnsignedBigInt
  fileName      String   @map("file_name") @db.VarChar(255)
  fileType      String   @map("file_type") @db.VarChar(50)
  fileSizeBytes BigInt   @map("file_size_bytes") @db.UnsignedBigInt
  fileUrl       String   @map("file_url") @db.VarChar(2048)
  uploadedAt    DateTime @default(now()) @map("uploaded_at")

  message  Message? @relation(fields: [messageId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  service  Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  uploader User     @relation(fields: [uploaderId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([messageId])
  @@index([serviceId])
  @@index([uploaderId])
  @@map("attachments")
}

// ============================================================
// MODERAÇÃO & ADMINISTRAÇÃO
// ============================================================

model Report {
  id                BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  uuid              Bytes        @unique @db.Binary(16)
  reporterId        BigInt       @map("reporter_id") @db.UnsignedBigInt
  reportedUserId    BigInt?      @map("reported_user_id") @db.UnsignedBigInt
  reportedServiceId BigInt?      @map("reported_service_id") @db.UnsignedBigInt
  reportType        String       @map("report_type") @db.VarChar(50)
  description       String       @db.Text
  status            ReportStatus @default(pending)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  reporter        User     @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  reportedUser    User?    @relation("ReportedUserReports", fields: [reportedUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  reportedService Service? @relation(fields: [reportedServiceId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([reporterId])
  @@index([reportedUserId])
  @@index([reportedServiceId])
  @@index([status])
  @@map("reports")
}

model AdminLog {
  id              BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  adminId         BigInt   @map("admin_id") @db.UnsignedBigInt
  actionType      String   @map("action_type") @db.VarChar(100)
  targetTable     String?  @map("target_table") @db.VarChar(100)
  targetId        BigInt?  @map("target_id") @db.UnsignedBigInt
  details         Json?
  actionTimestamp DateTime @default(now()) @map("action_timestamp")

  admin User @relation(fields: [adminId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([adminId])
  @@index([actionTimestamp(sort: Desc)])
  @@map("admin_logs")
}

// ============================================================
// ASSINATURAS
// ============================================================

model SubscriptionPlan {
  id           Int      @id @default(autoincrement()) @db.UnsignedTinyInt
  uuid         Bytes    @unique @db.Binary(16)
  name         String   @unique @db.VarChar(100)
  description  String?  @db.Text
  price        Decimal  @db.Decimal(10, 2)
  currency     String   @default("BRL") @db.VarChar(3)
  durationDays Int?     @map("duration_days") @db.UnsignedInt
  features     Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  userSubscriptions UserSubscription[]

  @@map("subscription_plans")
}

model UserSubscription {
  id         BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  uuid       Bytes              @unique @db.Binary(16)
  userId     BigInt             @map("user_id") @db.UnsignedBigInt
  planId     Int                @map("plan_id") @db.UnsignedTinyInt
  startDate  DateTime           @default(now()) @map("start_date")
  endDate    DateTime           @map("end_date")
  status     SubscriptionStatus @default(active)
  autoRenew  Boolean            @default(false) @map("auto_renew")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([planId])
  @@index([endDate])
  @@map("user_subscriptions")
}

// ============================================================
// ENUMS
// ============================================================

enum AvailabilityStatus {
  available
  busy
  offline
}

enum ProficiencyLevel {
  beginner
  intermediate
  advanced
  expert
}

enum ServiceStatus {
  draft
  open
  in_progress
  under_review
  completed
  cancelled
}

enum ProposalStatus {
  pending
  accepted
  rejected
  withdrawn
}

enum TransactionType {
  service_payment
  deposit
  withdrawal
  escrow_release
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
  in_escrow
  released_from_escrow
}

enum WalletTransactionType {
  credit
  debit
}

enum WalletTransactionStatus {
  pending
  completed
  failed
}

enum ReportStatus {
  pending
  reviewed
  resolved
  rejected
}

enum SubscriptionStatus {
  active
  cancelled
  expired
}
